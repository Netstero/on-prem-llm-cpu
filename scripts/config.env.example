# config.env — SINGLE SOURCE OF TRUTH for all tunable values (gpt-oss install).
#
# RULE: every value the scripts or docs need lives HERE, once. Scripts `source` it;
# docs cite the VARIABLE NAME, never restate the value. Change a value here, rerun
# install.sh → everything follows. If you find a literal value duplicated anywhere
# else, that's a bug — move it here and reference the name.

# --- CT access (consumed by your own SSH wrapper; not included in this repo) --
# Copy this file to config.env and fill in your values. config.env is gitignored.
CTID=<CTID>                     # Proxmox container ID
CT_HOST=<hostname>              # CT hostname
CT_IP=<CT_IP>                   # container LAN IP
CT_USER=<user>                  # SSH user with passwordless sudo
SSH_KEY="$HOME/.ssh/<your_key>" # private key path

# --- llama.cpp build --------------------------------------------------------
LLAMA_REPO="https://github.com/ggml-org/llama.cpp"
LLAMA_DIR="/opt/llama.cpp"
LLAMA_COMMIT="6e14286ed"        # pinned: built & verified 2026-06-14 (llama-server b9631); empty = master HEAD
# ik_llama.cpp — CPU/MoE-optimized fork; ~+87% prefill vs mainline, ~-5% decode (2026-06-14 A/B). DEFAULT engine.
IK_REPO="https://github.com/ikawrakow/ik_llama.cpp"
IK_DIR="/opt/ik_llama.cpp"
IK_COMMIT="670a3f6"             # built & verified 2026-06-14
BUILD_JOBS=8                    # -j for cmake; <nproc to keep the lab responsive

# --- model ------------------------------------------------------------------
MODEL_REPO="ggml-org/gpt-oss-20b-GGUF"
MODEL_FILE="gpt-oss-20b-mxfp4.gguf"     # native MXFP4 quant, ~12 GB (repo uses lowercase)
MODEL_DIR="/opt/models"

# --- serve (llama-server) ---------------------------------------------------
ACTIVE_MODEL=qwen               # which model the gpt-oss.service unit serves: gptoss | qwen. 30-systemd.sh reads this. Single-service swap (box can't hold both resident until CT cap ~44GB).
SERVE_BIN="$IK_DIR/build/bin/llama-server"   # current default = ik (mainline: $LLAMA_DIR/build/bin/llama-server). Final engine pending benchmark suite; harness overrides per-cell.
FA=""                           # flash attention OFF by default: on ik it costs ~26% short-ctx decode (14 vs 19 t/s, measured 2026-06-14). Set "-fa 1" only if long-context is the dominant workload (saves KV mem, helps decode at depth).
SERVE_HOST=0.0.0.0
PORT=8080
CTX=32768                       # 128K needs 48+ GB RAM; 32K is the CPU sweet spot
THREADS=11                      # leave 1 of the 12 pinned cores for the OS/sshd/pct-enter monitoring
SLOTS=1                         # parallel request slots; 1 = single-user. Each slot allocates its OWN full CTX KV — keep at 1 unless you need concurrent requests (memory scales linearly with SLOTS)
# Sampling — OpenAI's recommended values for GPT-OSS:
TEMP=1.0
TOP_P=1.0
TOP_K=0
MIN_P=0.0
# Hard rules baked into the serve cmd (NOT knobs): always --jinja;
# NO repetition penalty; NO KV-cache quant (--cache-type-k/v) → both degrade GPT-OSS.

# --- benchmark suite (scripts/bench-suite.sh) -------------------------------
REPS=3                          # measured repetitions per cell (median-summarized)
OUT_SHORT=64                    # max_tokens for short-output speed cells
OUT_LONG=2000                   # max_tokens for long-output speed cells (sustained decode)
RESULTS_BASE="$HOME/gpt-oss/results"   # raw artifacts + results.csv land here (DATA, not code)

# --- second model: Qwen3-Coder-30B-A3B (benchmark target, coexists with gpt-oss) ---
# Downloaded & integrity-verified 2026-06-16 (byte-exact to HF LFS size 17665334432).
# SEPARATE vars: they do NOT alter the live gpt-oss service. Wiring the harness to switch
# model is a tests-time change (pending). MoE 30.5B total / 3.3B active, Apache-2.0.
QWEN_MODEL_REPO="unsloth/Qwen3-Coder-30B-A3B-Instruct-GGUF"
QWEN_MODEL_FILE="Qwen3-Coder-30B-A3B-Instruct-UD-Q4_K_XL.gguf"   # Unsloth Dynamic 4-bit, ~17.7 GB; ships patched tool-call template
# Sampling — Qwen's official recommended values for Qwen3-Coder (differ from gpt-oss):
QWEN_TEMP=0.7
QWEN_TOP_P=0.8
QWEN_TOP_K=20
QWEN_MIN_P=0.0
QWEN_REPEAT_PENALTY=1.05         # Qwen recommends 1.05; gpt-oss uses NONE — harness needs a knob to apply this only for Qwen
# Apples-to-apples bench vs gpt-oss: reuse CTX=32768, THREADS=11, no KV-quant, same cells/tasks/reps.
# 31 GB CT cap now fits Q4 weights (~19 GB) + FP16 KV @32K (~3 GB) without KV quant. 64K cells possible later.

# --- host-side CPU pinning (USER applies on the Proxmox host; not these scripts) ---
CPUSET="0-11"                   # 12 physical-core primaries; verify map first: lscpu -e
